# ── Codebase Intelligence Agent — Environment Variables ─────────────────────
# Copy to .env and fill in your values. .env is gitignored; this file is committed.

# ── LLM Settings ──────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
AGENT_MODEL=llama3.1:8b
AGENT_VISION_MODEL=llava
OLLAMA_TIMEOUT=300

# ── Security ──────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AGENT_API_KEY=CHANGE_ME_generate_a_real_secret_key
# Set to true ONLY in local dev — disables auth completely
DISABLE_AUTH=false

# ── Database ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ── Embedding ─────────────────────────────────────────────────────────────────
EMBED_MODEL=BAAI/bge-small-en-v1.5

# ── API Server ────────────────────────────────────────────────────────────────
PORT=8000
ENV=production
# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000

# ── UI ────────────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
# Optional: pipe-separated example queries for UI chips
# EXAMPLE_QUERIES=What does the main entry point do?|How does error handling work?

# ── Memory ────────────────────────────────────────────────────────────────────
# Cosine distance threshold (0=identical, 1=unrelated). Lower = stricter.
MEMORY_RELEVANCE_THRESHOLD=0.35
